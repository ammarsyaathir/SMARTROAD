<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FB"
    android:clipToPadding="false"
    android:fillViewport="true"
    tools:context=".ReportFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="30dp">

        <!-- Page title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Report Road Hazard"
            android:textColor="#1C2B4A"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="18dp"
            android:lineSpacingExtra="2dp"
            android:text="Provide accurate information to help identify and manage road hazards."
            android:textColor="#7B879D"
            android:textSize="14sp" />

        <!-- Safety notice -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            app:cardBackgroundColor="#FFF7E8"
            app:cardCornerRadius="17dp"
            app:cardElevation="0dp"
            app:strokeColor="#F0D59D"
            app:strokeWidth="1dp">

        </com.google.android.material.card.MaterialCardView>

        <!-- Hazard information card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="20dp"
            app:cardElevation="1dp"
            app:strokeColor="#E7ECF4"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    android:text="Hazard Information"
                    android:textColor="#1C2B4A"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <!-- Hazard type dropdown -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutIssueType"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    android:hint="Type of hazard"
                    app:boxCornerRadiusBottomEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxStrokeColor="#2457D6"
                    app:hintTextColor="#667085"
                    app:startIconDrawable="@android:drawable/ic_dialog_alert"
                    app:startIconTint="#2457D6">

                    <AutoCompleteTextView
                        android:id="@+id/spinnerIssueType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Description -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutDescription"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    android:hint="Description and report details"
                    app:boxCornerRadiusBottomEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxStrokeColor="#2457D6"
                    app:counterEnabled="true"
                    app:counterMaxLength="500"
                    app:helperText="Describe the damage, road condition and nearby landmark."
                    app:hintTextColor="#667085">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDescription"
                        android:layout_width="match_parent"
                        android:layout_height="130dp"
                        android:gravity="top|start"
                        android:inputType="textCapSentences|textMultiLine"
                        android:maxLength="100"
                        android:paddingTop="16dp"
                        android:scrollbars="vertical" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- GPS coordinates -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutCoordinates"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Selected GPS coordinates"
                    app:boxCornerRadiusBottomEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxStrokeColor="#218558"
                    app:hintTextColor="#667085"
                    app:startIconDrawable="@android:drawable/ic_menu_mylocation"
                    app:startIconTint="#218558">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCoordinates"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="false"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:text="Getting GPS location..."
                        android:textColor="#667085" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Photo section heading -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hazard Evidence"
                    android:textColor="#1C2B4A"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Capture one clear photo showing the road condition"
                    android:textColor="#7B879D"
                    android:textSize="12sp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvPhotoStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_photo_required"
                android:paddingStart="10dp"
                android:paddingTop="5dp"
                android:paddingEnd="10dp"
                android:paddingBottom="5dp"
                android:text="Required"
                android:textColor="#B45309"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Photo preview -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPhotoPreview"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#E9EDF4"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="#D9E0EA"
            app:strokeWidth="1dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/ivReportImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="Hazard image preview"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    tools:src="@tools:sample/backgrounds/scenic"
                    tools:visibility="visible" />

                <LinearLayout
                    android:id="@+id/photoPlaceholder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        app:cardBackgroundColor="#DDE6F4"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_gravity="center"
                            android:contentDescription="Camera"
                            android:src="@android:drawable/ic_menu_camera"
                            app:tint="#60708A" />

                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="No hazard photo added"
                        android:textColor="#26344F"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:gravity="center"
                        android:lineSpacingExtra="2dp"
                        android:text="Make sure the hazard is clearly visible and avoid taking the photo while driving."
                        android:textColor="#7B879D"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Replace photo button shown over preview -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReplacePhoto"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="12dp"
                    android:text="Retake"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:backgroundTint="#CC1C2B4A"
                    app:cornerRadius="13dp"
                    app:icon="@android:drawable/ic_menu_camera"
                    app:iconTint="#FFFFFF"
                    tools:visibility="visible" />

            </FrameLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Photo guidance -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#F7F9FC"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="#E3E8F0"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="13dp">

                <ImageView
                    android:layout_width="21dp"
                    android:layout_height="21dp"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="Photo guidance"
                    android:src="@android:drawable/ic_dialog_info"
                    app:tint="#2563EB" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="For the best result, use good lighting and keep the camera steady."
                    android:textColor="#5F6B7C"
                    android:textSize="12sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Capture photo button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCaptureImage"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="12dp"
            android:text="Open Camera"
            android:textAllCaps="false"
            android:textColor="#218558"
            android:textSize="15sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_menu_camera"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="#218558"
            app:strokeColor="#218558"
            app:strokeWidth="1dp" />

        <!-- Submission loading -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/submissionProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:indicatorColor="#2457D6"
            app:trackColor="#DDE5F3"
            tools:visibility="visible" />

        <!-- Submit button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitReport"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Submit Road Hazard Report"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#2457D6"
            app:cornerRadius="17dp"
            app:elevation="2dp"
            app:icon="@android:drawable/ic_menu_send"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="#FFFFFF" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>