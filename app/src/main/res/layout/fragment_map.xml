<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FB"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingBottom="12dp"
    tools:context=".MapFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp">

        <!-- ========================================================= -->
        <!-- APPLICATION HEADER                                        -->
        <!-- ========================================================= -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SMARTROAD"
                    android:textColor="#1C2B4A"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Safer roads through community reporting"
                    android:textColor="#7B879D"
                    android:textSize="13sp" />

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="46dp"
                android:layout_height="46dp"
                app:cardBackgroundColor="#E7EEFF"
                app:cardCornerRadius="15dp"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:contentDescription="SmartRoad map"
                    android:src="@android:drawable/ic_dialog_map"
                    app:tint="#2457D6" />

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- ========================================================= -->
        <!-- USER AND GPS CARD                                         -->
        <!-- ========================================================= -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#1C2B4A"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.08"
                            android:text="WELCOME"
                            android:textColor="#BFD2FF"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvWelcome"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Welcome, Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutGpsStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_gps_status"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="10dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="6dp">

                        <View
                            android:id="@+id/viewGpsStatusDot"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_gps_dot" />

                        <TextView
                            android:id="@+id/tvGpsStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="GPS Active"
                            android:textColor="#65E69D"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_coordinate_container"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="13dp">

                    <ImageView
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:contentDescription="Current location"
                        android:src="@android:drawable/ic_menu_mylocation"
                        app:tint="#8DB5FF" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.06"
                            android:text="CURRENT GPS COORDINATES"
                            android:textColor="#BFD2FF"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Latitude"
                                    android:textColor="#AFC1E3"
                                    android:textSize="10sp" />

                                <TextView
                                    android:id="@+id/tvLatitude"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="Loading..."
                                    android:textColor="#7EC8FF"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Longitude"
                                    android:textColor="#AFC1E3"
                                    android:textSize="10sp" />

                                <TextView
                                    android:id="@+id/tvLongitude"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="Loading..."
                                    android:textColor="#7EC8FF"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRefreshLocation"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:contentDescription="Refresh current location"
                        android:insetLeft="0dp"
                        android:insetTop="0dp"
                        android:insetRight="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        app:backgroundTint="#314568"
                        app:cornerRadius="13dp"
                        app:icon="@android:drawable/ic_popup_sync"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconTint="#FFFFFF" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ========================================================= -->
        <!-- MAP INSTRUCTION                                           -->
        <!-- ========================================================= -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Tap anywhere on the map to select the location of the road hazard."
            android:textColor="#68758C"
            android:textSize="12sp" />

        <!-- ========================================================= -->
        <!-- GOOGLE MAP                                                -->
        <!-- ========================================================= -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="550dp"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="3dp"
            app:strokeColor="#DEE4EF"
            app:strokeWidth="1dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.fragment.app.FragmentContainerView
                    android:id="@+id/google_map"
                    android:name="com.google.android.gms.maps.SupportMapFragment"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMapType"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Change map type"
                    android:elevation="8dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Normal"
                    android:textAllCaps="false"
                    android:textColor="#1C2B4A"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:backgroundTint="#FFFFFF"
                    app:cornerRadius="13dp"
                    app:icon="@android:drawable/ic_dialog_map"
                    app:iconGravity="textStart"
                    app:iconPadding="7dp"
                    app:iconSize="18dp"
                    app:iconTint="#2457D6"
                    app:strokeColor="#D9E0EC"
                    app:strokeWidth="1dp" />

            </FrameLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ========================================================= -->
        <!-- REPORT BUTTON                                             -->
        <!-- ========================================================= -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoToReport"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="22dp"
            android:text="Report Hazard at This Location"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#2457D6"
            app:cornerRadius="17dp"
            app:elevation="2dp"
            app:icon="@android:drawable/ic_dialog_alert"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="#FFFFFF" />

        <!-- ========================================================= -->
        <!-- HAZARDS NEARBY HEADER                                     -->
        <!-- ========================================================= -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hazards Nearby"
                    android:textColor="#1C2B4A"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Reported hazards within 10 km of your location"
                    android:textColor="#7B879D"
                    android:textSize="12sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:background="@drawable/bg_live_badge"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="11dp"
                android:paddingEnd="11dp">

                <View
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:background="@drawable/bg_live_dot" />

                <TextView
                    android:id="@+id/tvHazardCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="7dp"
                    android:text="0 nearby"
                    android:textColor="#218558"
                    android:textSize="11sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- ========================================================= -->
        <!-- LOADING INDICATOR                                         -->
        <!-- ========================================================= -->

        <ProgressBar
            android:id="@+id/progressHazards"
            style="?android:attr/progressBarStyle"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:indeterminateTint="#2457D6"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- ========================================================= -->
        <!-- EMPTY STATE                                               -->
        <!-- ========================================================= -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardNoHazards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:visibility="visible"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeColor="#E5EAF2"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:contentDescription="No nearby hazards"
                    android:src="@android:drawable/ic_dialog_info"
                    app:tint="#95A1B5" />

                <TextView
                    android:id="@+id/tvNoHazards"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:text="No nearby hazards found"
                    android:textColor="#26344F"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:gravity="center"
                    android:text="New community reports will appear here automatically."
                    android:textColor="#7B879D"
                    android:textSize="12sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ========================================================= -->
        <!-- NEARBY HAZARD LIST                                        -->
        <!-- ========================================================= -->

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerNearbyHazards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never"
            android:visibility="gone"
            tools:itemCount="3"
            tools:listitem="@layout/item_nearby_hazard"
            tools:visibility="visible" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>